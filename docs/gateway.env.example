# =============================================================================
# EVA Agent — Gateway / messaging env template (NO REAL SECRETS)
# =============================================================================
# Copy to:  %LOCALAPPDATA%\eva\.env   (Windows)
#       or:  ~/.eva/.env               (POSIX)
#
# NEVER commit a filled .env. Placeholders only in this file.
# Full catalog of optional vars: see repo root .env.example
# Wizard alternative:  eva gateway setup
# =============================================================================

# --- Model provider (at least one path; secrets go here, not in config.yaml) ---
# OPENROUTER_API_KEY=REPLACE_ME
# ANTHROPIC_API_KEY=REPLACE_ME
# OPENAI_API_KEY=REPLACE_ME
# NOUS_API_KEY=REPLACE_ME
# Or use: eva auth / eva setup  (OAuth flows write managed credentials)

# --- Telegram (most common first path) ---
# Token from @BotFather → https://t.me/BotFather  (human copies from UI)
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOTFATHER_TOKEN
# Numeric user IDs only (not @username). Get via @userinfobot
TELEGRAM_ALLOWED_USERS=REPLACE_WITH_YOUR_NUMERIC_USER_ID
# TELEGRAM_HOME_CHANNEL=REPLACE_WITH_CHAT_ID_FOR_CRON
# TELEGRAM_HOME_CHANNEL_NAME=home

# Optional webhook mode (cloud). Default = long polling (fine for home PC).
# TELEGRAM_WEBHOOK_URL=https://example.invalid/telegram
# TELEGRAM_WEBHOOK_PORT=8443
# TELEGRAM_WEBHOOK_SECRET=REPLACE_ME

# --- Discord ---
# DISCORD_BOT_TOKEN=REPLACE_ME
# DISCORD_ALLOWED_USERS=REPLACE_ME

# --- Slack (Socket Mode) ---
# SLACK_BOT_TOKEN=xoxb-REPLACE_ME
# SLACK_APP_TOKEN=xapp-REPLACE_ME
# SLACK_ALLOWED_USERS=U_REPLACE_ME

# --- WhatsApp (pair via: eva whatsapp) ---
# WHATSAPP_ENABLED=false
# WHATSAPP_ALLOWED_USERS=15551234567

# --- Gateway authorization ---
# Default deny if no allowlists / pairing. Do NOT enable open access casually.
# GATEWAY_ALLOW_ALL_USERS=false
# GATEWAY_ALLOWED_USERS=

# --- Working directory for tools launched from messaging (optional) ---
# Prefer config.yaml → terminal.cwd  (not secrets)
